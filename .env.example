# URL base para la API de inferencia (ej. GitHub Models)
OPENAI_BASE_URL="https://models.github.ai/inference"

# Token de acceso personal de GitHub (Classic o Fine-grained con acceso a GitHub Models)
GITHUB_TOKEN="tu_github_token_aqui"

# Modelo de LLM a utilizar (ej. gpt-4o-mini, gpt-4o, etc.)
MODEL="gpt-4o-mini"

# Configuración opcional para LangSmith (Tracing y monitoreo)
# LANGSMITH_TRACING="true"
# LANGSMITH_API_KEY="tu_langsmith_api_key_aqui"
# LANGSMITH_PROJECT="tu_nombre_de_proyecto_aqui"
